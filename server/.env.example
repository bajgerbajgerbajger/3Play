# 3Play Video Platform - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# Database
# ============================================
MONGODB_URI=mongodb://localhost:27017/3play

# ============================================
# JWT Secrets (generate strong random strings)
# ============================================
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# ============================================
# Client URL (for CORS and email links)
# ============================================
CLIENT_URL=http://localhost:5173

# ============================================
# Email Configuration
# ============================================

# Option 1: SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Option 2: SendGrid (alternative to SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key

# Email From Configuration
EMAIL_FROM_NAME=3Play Video Platform
EMAIL_FROM_ADDRESS=noreply@example.com
SUPPORT_EMAIL=support@example.com

# Development: Use Ethereal for testing (set to 'true' to enable)
USE_ETHEREAL=false

# ============================================
# Trusted IP Ranges (Email Service Provider)
# ============================================
# Comma-separated list of CIDR ranges for trusted email provider IPs
# These IPs are whitelisted for:
#   - SMTP server communication
#   - Webhook verification
#   - Rate limiting exceptions
#
# Default ranges (used by email service provider):
#   74.220.51.0/24 - SMTP outbound servers
#   74.220.59.0/24 - Webhook callback servers
#
# To customize, uncomment and modify:
# TRUSTED_IP_RANGES=74.220.51.0/24,74.220.59.0/24

# ============================================
# File Upload Configuration
# ============================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# Optional: Rate Limit Overrides
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
